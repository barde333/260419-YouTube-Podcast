# API Key pour protéger les endpoints d'ajout/suppression
API_KEY=your_secret_api_key_here

# Configuration Flask
FLASK_ENV=production
FLASK_DEBUG=0

# Base de données (chemin volume Docker)
DATABASE_URL=sqlite:////app/data/podcast.db

# Paramètres de conversion
YT_DLP_COOKIES_FILE=/app/data/cookies.txt
MAX_WORKERS=2

# Paramètres du flux RSS
PODCAST_TITLE=My YouTube Podcast
PODCAST_DESCRIPTION=Convert YouTube videos to audio
PODCAST_LANGUAGE=en
PODCAST_AUTHOR=Anonymous

# Domaine public
PUBLIC_URL=https://podcast.bard3.duckdns.org

# Stockage des MP3
STORAGE_DIR=/app/data/mp3
