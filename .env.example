# API Key pour protéger les endpoints d'ajout/suppression (étape 6)
API_KEY=your_secret_api_key_here

# Configuration Flask
FLASK_DEBUG=0

# Chemins (volumes Docker)
DB_PATH=/data/podcast.db
MEDIA_DIR=/data/media

# Paramètres de conversion (étape 3)
YT_DLP_COOKIES_FILE=/data/cookies.txt
MAX_WORKERS=2

# Paramètres du flux RSS (étape 4)
PODCAST_TITLE=My YouTube Podcast
PODCAST_DESCRIPTION=Convert YouTube videos to audio
PODCAST_LANGUAGE=fr
PODCAST_AUTHOR=Anonymous
PUBLIC_URL=https://podcast.bard3.duckdns.org
